@page "/bookings"
@rendermode InteractiveServer
@inject BookingApiClient Api

<PageTitle>Bookings</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Bookings</h2>
</div>

@if (_loading)
{
    <div class="d-flex align-items-center gap-2 text-muted">
        <div class="spinner-border spinner-border-sm" role="status"></div>
        <span>Loading bookings…</span>
    </div>
}
else if (_error is not null)
{
    <div class="alert alert-danger d-flex justify-content-between align-items-center">
        <span>@_error</span>
        <button class="btn btn-sm btn-outline-danger" @onclick="LoadAsync">Retry</button>
    </div>
}
else if (Upcoming.Count == 0)
{
    <p class="text-muted fst-italic">No upcoming bookings. Bookings are created automatically when a Zoezi confirmation email arrives (sync on the Emails page).</p>
}
else
{
    <table class="table align-middle">
        <thead>
            <tr>
                <th>Class</th>
                <th>Starts</th>
                <th>Ends</th>
                <th>Platform</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var booking in Upcoming)
            {
                <tr>
                    <td>@booking.Title</td>
                    <td>@booking.StartTime.LocalDateTime.ToString("ddd d MMM, HH:mm")</td>
                    <td>@(booking.EndTime?.LocalDateTime.ToString("HH:mm") ?? "—")</td>
                    <td><span class="badge bg-secondary">@(booking.Platform ?? "Manual")</span></td>
                </tr>
            }
        </tbody>
    </table>
    <p class="text-muted small">@Upcoming.Count upcoming booking(s).</p>
}

@code {
    private List<BookingResponseDto> _bookings = new();
    private bool _loading = true;
    private string? _error;

    private List<BookingResponseDto> Upcoming =>
        _bookings.Where(b => b.StartTime >= DateTimeOffset.Now).ToList();

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        _error = null;
        try
        {
            _bookings = (await Api.GetBookingsAsync()).ToList();
        }
        catch (Exception ex)
        {
            _error = $"Could not load bookings: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }
}
